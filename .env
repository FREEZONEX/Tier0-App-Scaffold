# ─── 必填 ───
DATABASE_URL="postgresql://appbuilder:appbuilder@localhost:5432/proj-abc123"

# Session cookie 签名密钥（>= 32 字符）。生产环境必填。
# 本地不设：每次重启会随机生成，已发出的 session 全部失效。
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET="replace-with-32-plus-character-random-string"

# ─── 可选：绕过连接池直连（drizzle-kit push / seed 优先使用）───
# DIRECT_DATABASE_URL="postgresql://appbuilder:appbuilder@localhost:5432/proj-abc123"

# ─── 以下由平台注入，本地开发不设。设了即启用对应能力 ───

# 数据库 schema 隔离（不设则用 public）
# DB_SCHEMA="session-abc123"

# 应用标识，与 DB_SCHEMA 一致（不设则默认 "monoapp"）
# APP_ID="session-abc123"

# URL 前缀（不设则无前缀）
# VITE_BASE_PATH="/session-abc123"
# 兼容旧名（apiUrl 仍读取，便于平台过渡）
# NEXT_PUBLIC_BASE_PATH="/session-abc123"

# 设了则 SSO 登录按钮显示，网关认证生效；不设则只有本地登录
# NEXT_PUBLIC_GATEWAY_URL="https://gateway.example.com"
# NEXT_PUBLIC_GATEWAY_LOGIN_PATH="/login"
# GATEWAY_CHECK_TOKEN_URL="http://gateway-internal:8795/api/bff/auth/check-token"
