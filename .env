# ─── Database (required) ───
DATABASE_URL="postgresql://appbuilder:appbuilder@localhost:6432/mes"

# If using a connection pooler (e.g. PgBouncer), set the direct URL for migrations/seed:
# DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/mes"

# ─── App Identity ───
# APP_ID="monoapp"

# ─── Base Path (set by platform preview proxy, usually leave empty) ───
# NEXT_PUBLIC_BASE_PATH=""

# ─── SSO / Gateway (leave commented out for local development) ───
# When deployed behind gwsvr gateway, uncomment and configure:
# NEXT_PUBLIC_GATEWAY_URL="https://gateway.example.com"
# NEXT_PUBLIC_GATEWAY_LOGIN_PATH="/login"
# GATEWAY_CHECK_TOKEN_URL="http://gateway-internal:8795/api/bff/auth/check-token"
